 // NewAgent creates a new Agent with core tools and optional MCP tool integration.
 // Core tools (bash, read, write, edit, grep, find, ls) are always registered.
+// CoreToolsForPolicy returns the set of core tools enabled by the given policy.
+// Every tool is opt-in: a field must be explicitly set to true in the user's
+// config for the corresponding tool to be registered with the agent.
+// This is the single source of truth for policy-driven tool selection.
+func CoreToolsForPolicy(policy config.CoreToolsConfig) []fantasy.AgentTool {
+	var tools []fantasy.AgentTool
+	if policy.Bash {
+		tools = append(tools, core.NewBashTool())
+	}
+	if policy.Read {
+		tools = append(tools, core.NewReadTool())
+	}
+	if policy.Write {
+		tools = append(tools, core.NewWriteTool())
+	}
+	if policy.Edit {
+		tools = append(tools, core.NewEditTool())
+	}
+	if policy.Search {
+		tools = append(tools, core.NewGrepTool(), core.NewFindTool())
+	}
+	if policy.List {
+		tools = append(tools, core.NewLsTool())
+	}
+	if policy.Subagent {
+		tools = append(tools, core.NewSubagentTool())
+	}
+	return tools
+}
+
 // If MCP servers are configured, their tools are loaded in the background —
 // the agent returns immediately and is usable with core tools only. The first
 // LLM call (GenerateWithLoop) automatically waits for MCP tools to finish
@@ -290,8 +320,13 @@ func NewAgent(ctx context.Context, agentConfig *AgentConfig) (*Agent, error) {
 		// Custom tools provided - use them
 		coreTools = agentConfig.CoreTools
 	} else {
-		// Default: load all core tools
-		coreTools = core.AllTools()
+		// Default: use policy-filtered core tools (secure-by-default).
+		// Users opt in through the coreTools section of their config file.
+		var policy config.CoreToolsConfig
+		if agentConfig.MCPConfig != nil {
+			policy = agentConfig.MCPConfig.CoreTools
+		}
+		coreTools = CoreToolsForPolicy(policy)
 	}
 
 	// Build the initial tool list: core tools + extension tools (no MCP yet).
