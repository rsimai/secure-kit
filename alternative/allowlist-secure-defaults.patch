 // NewAgent creates a new Agent with core tools and optional MCP tool integration.
 // Core tools (bash, read, write, edit, grep, find, ls) are always registered.
+// FilterTools applies an allowlist/denylist policy to a tool set.
+// - Only tools listed in enabledTools are included.
+// - Tools listed in disabledTools are always excluded, even if in enabledTools.
+// - If enabledTools is nil or empty, zero tools are returned (secure by default).
+//
+// This enables secure-by-default configurations: without explicit configuration,
+// no tools are registered with the agent.
+func FilterTools(allTools []fantasy.AgentTool, enabledTools, disabledTools []string) []fantasy.AgentTool {
+	var result []fantasy.AgentTool
+
+	// Secure by default: if enabledTools is nil or empty, return zero tools
+	if len(enabledTools) == 0 {
+		return result
+	}
+
+	for _, tool := range allTools {
+		name := extractToolName(tool)
+
+		// Check if tool is in allowlist
+		found := false
+		for _, enabled := range enabledTools {
+			if name == enabled {
+				found = true
+				break
+			}
+		}
+		if !found {
+			continue
+		}
+
+		// Check if tool is in denylist
+		if len(disabledTools) > 0 {
+			blocked := false
+			for _, disabled := range disabledTools {
+				if name == disabled {
+					blocked = true
+					break
+				}
+			}
+			if blocked {
+				continue
+			}
+		}
+
+		result = append(result, tool)
+	}
+	return result
+}
