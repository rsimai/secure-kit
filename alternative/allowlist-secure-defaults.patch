diff --git a/internal/agent/tools.go b/internal/agent/tools.go
new file mode 100644
index 00000000..xxxxxxxx
--- /dev/null
+++ b/internal/agent/tools.go
@@ -0,0 +1,33 @@
+package agent
+
+import (
+	"reflect"
+	"strings"
+
+	"charm.land/fantasy"
+)
+
+// extractToolName derives a tool's identifier from its type name.
+// Examples: BashTool -> "bash", ReadTool -> "read", GrepTool -> "grep"
+//
+// This enables runtime-based tool filtering without hardcoding tool names,
+// making the filter future-proof when new tools are added to kit.
+func extractToolName(tool fantasy.AgentTool) string {
+	t := reflect.TypeOf(tool)
+
+	// Handle pointer types
+	if t.Kind() == reflect.Ptr {
+		t = t.Elem()
+	}
+
+	name := t.Name()
+
+	// Strip "Tool" suffix: BashTool -> Bash
+	if len(name) > 4 && strings.HasSuffix(name, "Tool") {
+		name = name[:len(name)-4]
+	}
+
+	// Convert to lowercase: Bash -> bash
+	name = strings.ToLower(name)
+
+	return name
+}
