+// ToolsForPolicy returns the core tool set allowed by the provided policy.
+// This enables secure-by-default deployments where tool access is opt-in.
+func ToolsForPolicy(policy BashPolicy, fsPolicy FilesystemPolicy, opts ...ToolOption) []fantasy.AgentTool {
+	allOpts := append([]ToolOption{}, opts...)
+	allOpts = append(allOpts, WithBashPolicy(policy), WithFilesystemPolicy(fsPolicy))
+
+	var tools []fantasy.AgentTool
+	if policy.Enabled {
+		tools = append(tools, NewBashTool(allOpts...))
+	}
+	if fsPolicy.Read {
+		tools = append(tools, NewReadTool(allOpts...))
+	}
+	if fsPolicy.Write {
+		tools = append(tools, NewWriteTool(allOpts...))
+	}
+	if fsPolicy.Edit {
+		tools = append(tools, NewEditTool(allOpts...))
+	}
+	if fsPolicy.Search {
+		tools = append(tools, NewGrepTool(allOpts...))
+		tools = append(tools, NewFindTool(allOpts...))
+	}
+	if fsPolicy.List {
+		tools = append(tools, NewLsTool(allOpts...))
+	}
+	tools = append(tools, NewSubagentTool(allOpts...))
+	return tools
+}
+
+func isPathAllowed(absPath, workDir string, allowedPaths []string) (bool, error) {
+	if len(allowedPaths) == 0 {
+		return false, nil
+	}
+	cleanTarget := filepath.Clean(absPath)
+	for _, p := range allowedPaths {
+		if strings.TrimSpace(p) == "" {
+			continue
+		}
+		resolved, err := resolvePathWithWorkDir(p, workDir)
+		if err != nil {
+			return false, err
+		}
+		cleanRoot := filepath.Clean(resolved)
+		rel, err := filepath.Rel(cleanRoot, cleanTarget)
+		if err != nil {
+			continue
+		}
+		if rel == "." || (rel != ".." && !strings.HasPrefix(rel, ".."+string(os.PathSeparator))) {
+			return true, nil
+		}
+	}
+	return false, nil
+}
+
+func fileAccessDeniedResponse(path string) fantasy.ToolResponse {
+	return fantasy.NewTextErrorResponse(
+		fmt.Sprintf("access to path '%s' is denied by coreTools.filesystem.allowedPaths policy", path),
+	)
+}
