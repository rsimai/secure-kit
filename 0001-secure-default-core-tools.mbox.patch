+func validateBashCommandPolicy(command string, policy BashPolicy) error {
+	segments := splitCommandSegments(command)
+	if len(segments) == 0 {
+		return nil
+	}
+
+	allowed := make(map[string]struct{})
+	for _, c := range policy.AllowedCommands {
+		cmd := strings.TrimSpace(c)
+		if cmd == "" {
+			continue
+		}
+		allowed[cmd] = struct{}{}
+	}
+	blocked := make(map[string]struct{})
+	for _, c := range policy.BlockedCommands {
+		cmd := strings.TrimSpace(c)
+		if cmd == "" {
+			continue
+		}
+		blocked[cmd] = struct{}{}
+	}
+
+	for _, seg := range segments {
+		cmd := firstCommandToken(seg)
+		if cmd == "" {
+			continue
+		}
+		if _, denied := blocked[cmd]; denied {
+			return fmt.Errorf("command '%s' is blocked by coreTools.bash.blockedCommands policy", cmd)
+		}
+		if len(allowed) > 0 {
+			if _, ok := allowed[cmd]; !ok {
+				allowedList := make([]string, 0, len(allowed))
+				for k := range allowed {
+					allowedList = append(allowedList, k)
+				}
+				sort.Strings(allowedList)
+				return fmt.Errorf("command '%s' is not allowed by coreTools.bash.allowedCommands policy (allowed: %s)", cmd, strings.Join(allowedList, ", "))
+			}
+		}
+	}
+
+	return nil
+}
+
+func splitCommandSegments(command string) []string {
+	replacer := strings.NewReplacer("&&", ";", "||", ";", "|", ";")
+	normalized := replacer.Replace(command)
+	parts := strings.Split(normalized, ";")
+	segments := make([]string, 0, len(parts))
+	for _, p := range parts {
+		if s := strings.TrimSpace(p); s != "" {
+			segments = append(segments, s)
+		}
+	}
+	return segments
+}
+
+func firstCommandToken(segment string) string {
+	tokens := strings.Fields(segment)
+	for _, tok := range tokens {
+		if strings.Contains(tok, "=") && !strings.HasPrefix(tok, "=") {
+			parts := strings.SplitN(tok, "=", 2)
+			if parts[0] != "" && parts[1] != "" {
+				continue
+			}
+		}
+		return tok
+	}
+	return ""
+}
